{
  "compilerOptions": {
    "strict": true,
    "allowJs": true,
    "composite": true,
    "skipLibCheck": true,
    "importHelpers": true,
    "noEmitOnError": true,
    "declarationMap": true,
    "isolatedModules": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "noImplicitOverride": true,
    "emitDeclarationOnly": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "module": "esnext",
    "target": "es6",
    "lib": [
      "esnext"
    ],
    "customConditions": [
      "@unibrowse/source"
    ]
  }
}
